PORT=4000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/transitops
JWT_SECRET=your_jwt_signing_secret_key_here

# Email Service Configuration (For expiring license reminders)
EMAIL_HOST=smtp.your-email-provider.com
